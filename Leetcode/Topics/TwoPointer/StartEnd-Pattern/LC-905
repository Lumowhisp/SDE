class Solution {
public:
    vector<int> sortArrayByParity(vector<int>& nums) {
        int i=0;
        int j=nums.size()-1;
        while(i<=j){
            if(!(nums[i]&1)){
                i++;
            }
            else{
                if(!(nums[j]&1)){
                    swap(nums[i],nums[j]);
                    i++;
                    j--;
                }
                else{
                    j--;
                }
            }

        }
        return nums;
    }
};